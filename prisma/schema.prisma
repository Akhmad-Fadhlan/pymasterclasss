datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ==========================================
// Enums
// ==========================================

enum UserRoleEnum {
  ADMIN
  INSTRUCTOR
  STUDENT
}

enum CourseLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum CourseStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUND
}

enum SubmissionStatus {
  PENDING
  REVIEW
  REVISION
  APPROVED
  REJECTED
}

// ==========================================
// Models
// ==========================================

model Role {
  id          String       @id @default(uuid()) @db.Uuid
  name        UserRoleEnum @unique
  description String?      @db.Text
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  users       User[]

  @@map("roles")
}

model User {
  id               String            @id @default(uuid()) @db.Uuid
  roleId           String            @db.Uuid
  fullName         String            @db.VarChar(255)
  username         String            @unique @db.VarChar(100)
  email            String            @unique @db.VarChar(255)
  avatar           String?           @db.VarChar(255)
  bio              String?           @db.Text
  phone            String?           @db.VarChar(30)
  isVerified       Boolean           @default(false)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  
  // Audit fields
  createdBy        String?           @db.Uuid
  updatedBy        String?           @db.Uuid

  // Relations
  role             Role              @relation(fields: [roleId], references: [id])
  enrollments      Enrollment[]
  quizAttempts     QuizAttempt[]
  progress         Progress[]
  submissions      Submission[]
  certificates     Certificate[]
  payments         Payment[]
  notifications    Notification[]
  achievements     UserAchievement[]
  activityLogs     ActivityLog[]

  @@index([email])
  @@index([username])
  @@index([createdAt])
  @@map("users")
}

model Category {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @db.VarChar(255)
  slug        String   @unique @db.VarChar(255)
  icon        String?  @db.VarChar(255)
  description String?  @db.Text
  orderNumber Int
  courses     Course[]

  // Audit fields
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdBy   String?  @db.Uuid
  updatedBy   String?  @db.Uuid

  @@index([slug])
  @@map("categories")
}

model Course {
  id               String        @id @default(uuid()) @db.Uuid
  categoryId       String        @db.Uuid
  title            String        @db.VarChar(255)
  slug             String        @unique @db.VarChar(255)
  shortDescription String        @db.VarChar(255)
  description      String        @db.Text
  thumbnail        String?       @db.VarChar(255)
  level            CourseLevel
  duration         Int           // in minutes
  price            Decimal       @db.Decimal(12, 2)
  status           CourseStatus  @default(DRAFT)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  // Audit fields
  createdBy        String?       @db.Uuid
  updatedBy        String?       @db.Uuid

  // Relations
  category         Category      @relation(fields: [categoryId], references: [id])
  enrollments      Enrollment[]
  missions         Mission[]
  certificates     Certificate[]

  @@index([slug])
  @@index([categoryId])
  @@index([createdAt])
  @@index([status])
  @@map("courses")
}

model Enrollment {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @db.Uuid
  courseId    String    @db.Uuid
  progress    Float     @default(0.0)
  startedAt   DateTime  @default(now())
  completedAt DateTime?

  // Relations
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  course      Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([courseId])
  @@index([startedAt])
  @@map("enrollments")
}

model Mission {
  id          String    @id @default(uuid()) @db.Uuid
  courseId    String    @db.Uuid
  title       String    @db.VarChar(255)
  description String    @db.Text
  orderNumber Int
  xpReward    Int       @default(0)

  // Audit fields
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  createdBy   String?   @db.Uuid
  updatedBy   String?   @db.Uuid

  // Relations
  course      Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons     Lesson[]
  projects    Project[]

  @@index([courseId])
  @@map("missions")
}

model Lesson {
  id          String     @id @default(uuid()) @db.Uuid
  missionId   String     @db.Uuid
  title       String     @db.VarChar(255)
  slug        String     @unique @db.VarChar(255)
  duration    Int        // in minutes
  orderNumber Int

  // Audit fields
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  createdBy   String?    @db.Uuid
  updatedBy   String?    @db.Uuid

  // Relations
  mission     Mission    @relation(fields: [missionId], references: [id], onDelete: Cascade)
  slides      Slide[]
  practices   Practice[]
  quizzes     Quiz[]
  progresses  Progress[]

  @@index([slug])
  @@index([missionId])
  @@map("lessons")
}

model Slide {
  id          String   @id @default(uuid()) @db.Uuid
  lessonId    String   @db.Uuid
  title       String   @db.VarChar(255)
  content     Json
  orderNumber Int

  // Audit fields
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdBy   String?  @db.Uuid
  updatedBy   String?  @db.Uuid

  // Relations
  lesson      Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([lessonId])
  @@map("slides")
}

model Practice {
  id             String   @id @default(uuid()) @db.Uuid
  lessonId       String   @db.Uuid
  title          String   @db.VarChar(255)
  instruction    String   @db.Text
  starterCode    String   @db.Text
  expectedOutput String   @db.Text

  // Audit fields
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  createdBy      String?  @db.Uuid
  updatedBy      String?  @db.Uuid

  // Relations
  lesson         Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([lessonId])
  @@map("practices")
}

model Quiz {
  id           String        @id @default(uuid()) @db.Uuid
  lessonId     String        @db.Uuid
  title        String        @db.VarChar(255)
  passingScore Int           @default(70)
  duration     Int           // in minutes

  // Audit fields
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  createdBy    String?       @db.Uuid
  updatedBy    String?       @db.Uuid

  // Relations
  lesson       Lesson        @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  questions    Question[]
  attempts     QuizAttempt[]

  @@index([lessonId])
  @@map("quizzes")
}

model Question {
  id          String   @id @default(uuid()) @db.Uuid
  quizId      String   @db.Uuid
  question    String   @db.Text
  explanation String   @db.Text
  orderNumber Int
  answers     Answer[]

  // Relations
  quiz        Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([quizId])
  @@map("questions")
}

model Answer {
  id         String   @id @default(uuid()) @db.Uuid
  questionId String   @db.Uuid
  answer     String   @db.Text
  isCorrect  Boolean  @default(false)

  // Relations
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
  @@map("answers")
}

model QuizAttempt {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @db.Uuid
  quizId     String   @db.Uuid
  score      Float
  startedAt  DateTime @default(now())
  finishedAt DateTime

  // Relations
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  quiz       Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([quizId])
  @@map("quiz_attempts")
}

model Progress {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @db.Uuid
  lessonId   String   @db.Uuid
  percentage Float    @default(0.0)
  completed  Boolean  @default(false)

  // Relations
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson     Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId])
  @@index([lessonId])
  @@map("progress")
}

model Project {
  id          String       @id @default(uuid()) @db.Uuid
  missionId   String       @db.Uuid
  title       String       @db.VarChar(255)
  rubric      Json
  maxScore    Int          @default(100)

  // Audit fields
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  createdBy   String?      @db.Uuid
  updatedBy   String?      @db.Uuid

  // Relations
  mission     Mission      @relation(fields: [missionId], references: [id], onDelete: Cascade)
  submissions Submission[]

  @@index([missionId])
  @@map("projects")
}

model Submission {
  id            String           @id @default(uuid()) @db.Uuid
  projectId     String           @db.Uuid
  userId        String           @db.Uuid
  repositoryUrl String           @db.VarChar(255)
  liveUrl       String?          @db.VarChar(255)
  attachment    String?          @db.VarChar(255)
  feedback      String?          @db.Text
  score         Float?
  status        SubmissionStatus @default(PENDING)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  // Relations
  project       Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([projectId])
  @@index([status])
  @@map("submissions")
}

model Certificate {
  id                String   @id @default(uuid()) @db.Uuid
  userId            String   @db.Uuid
  courseId          String   @db.Uuid
  certificateNumber String   @unique @db.VarChar(100)
  fileUrl           String   @db.VarChar(255)
  issuedAt          DateTime @default(now())

  // Relations
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course            Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([courseId])
  @@map("certificates")
}

model Payment {
  id                String        @id @default(uuid()) @db.Uuid
  userId            String        @db.Uuid
  amount            Decimal       @db.Decimal(12, 2)
  paymentMethod     String        @db.VarChar(100)
  paymentStatus     PaymentStatus @default(PENDING)
  transactionNumber String        @unique @db.VarChar(100)
  paidAt            DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  // Relations
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([paymentStatus])
  @@index([createdAt])
  @@map("payments")
}

model Notification {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  title     String   @db.VarChar(255)
  message   String   @db.Text
  type      String   @db.VarChar(50)
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  // Relations
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("notifications")
}

model Achievement {
  id               String            @id @default(uuid()) @db.Uuid
  title            String            @db.VarChar(255)
  icon             String            @db.VarChar(255)
  xp               Int
  userAchievements UserAchievement[]

  @@map("achievements")
}

model UserAchievement {
  id            String      @id @default(uuid()) @db.Uuid
  userId        String      @db.Uuid
  achievementId String      @db.Uuid
  earnedAt      DateTime    @default(now())

  // Relations
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_achievements")
}

model Announcement {
  id        String   @id @default(uuid()) @db.Uuid
  title     String   @db.VarChar(255)
  content   String   @db.Text
  publishAt DateTime

  @@map("announcements")
}

model Settings {
  id              String  @id @default(uuid()) @db.Uuid
  siteName        String  @db.VarChar(255)
  siteLogo        String  @db.VarChar(255)
  maintenanceMode Boolean @default(false)

  @@map("settings")
}

model ActivityLog {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  action    String   @db.VarChar(255)
  module    String   @db.VarChar(100)
  ipAddress String?  @db.VarChar(45)
  createdAt DateTime @default(now())

  // Relations
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("activity_logs")
}
